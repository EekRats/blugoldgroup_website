# - Eek, 04/23/2026
# about, calendar, discord, github
:8080 {
    templates
    #root * /var/www/blugoldgroup_website
    #file_server

    handle_path /about {
        rewrite * /about.html
        root * /var/www/blugoldgroup_website
        file_server
    }
    handle_path /calendar {
        redir https://example.com permanent
    }
    handle_path /discord {
        redir https://discord.gg/MHhBFZth7b permanent
    }
    handle_path /github {
        redir https://github.com/blugold-group permanent
    }
    handle_path / {
        root * /var/www/blugoldgroup_website/index.html
        file_server
    }

    # helps with *some* kind of security. look at https://securityheaders.com to test websites
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; style-src 'self' fonts.googleapis.com; font-src fonts.gstatic.com; img-src 'self'"
        -Server
    }

    @static path *.css *.js *.png *.ico *.webp *.woff2
    header @static Cache-Control "public, max-age=604800"

    log {
        output file /var/log/caddy/blugoldgroup.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

